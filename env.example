# Fasiri – environment variables
# Copy this file to .env and fill in your values.
# The server runs in stub/demo mode when provider keys are empty.

# ── Provider credentials ─────────────────────────────────────────────────────

# HuggingFace token (free tier works)
# Get it at: https://huggingface.co/settings/tokens  (Read token is enough)
HUGGINGFACE_API_KEY=hf_...

# Sunbird AI JWT token
# HOW TO GET IT (one-time setup):
#
#   Step 1 – Register (only once):
#   curl -X POST https://api.sunbird.ai/auth/register \
#        -H "Content-Type: application/json" \
#        -d '{"email":"you@example.com","password":"yourpassword"}'
#
#   Step 2 – Login to get your JWT:
#   curl -X POST https://api.sunbird.ai/auth/token \
#        -H "Content-Type: application/x-www-form-urlencoded" \
#        -d "username=you@example.com&password=yourpassword"
#
#   Step 3 – Copy the access_token value below (starts with "ey...")
#   NOTE: Tokens expire — re-run Step 2 to refresh.
#
SUNBIRD_API_KEY=ey...

# ── Fasiri internal auth ───────────────────────────────────────────────────
# Secret for signing API keys. Generate with: openssl rand -hex 32
FASIRI_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# How long issued keys stay valid in seconds (default = 1 year)
API_KEY_TTL_SECONDS=31536000

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_BATCH_RPM=10

# ── Redis (optional – for production rate limiting) ──────────────────────────
# Leave empty to use in-memory rate limiting (not shared across workers)
REDIS_URL=

# ── Provider base URLs ────────────────────────────────────────────────────────
SUNBIRD_BASE_URL=https://api.sunbird.ai

# IMPORTANT: HuggingFace changed their Inference API URL in late 2025.
# Old (DEAD - returns 404): https://api-inference.huggingface.co/models
# New (LIVE):
HUGGINGFACE_BASE_URL=https://router.huggingface.co/hf-inference/models

# ── Fallback model ────────────────────────────────────────────────────────────
# Helsinki multilingual — free on HF router, covers 100+ languages
# NOTE: facebook/nllb-200-distilled-600M is no longer free on HF Inference API
DEFAULT_MODEL_ID=Helsinki-NLP/opus-mt-en-mul

# ── Misc ──────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
DEBUG=false
HTTP_TIMEOUT=30
HTTP_TIMEOUT_STT=60
