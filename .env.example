# ─────────────────────────────────────────────────────────────
# Fasiri API – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Provider credentials ──────────────────────────────────────
# Sunbird AI (Ugandan languages: lug, ach, teo, nyn, lgg)
# Register: https://api.sunbird.ai/auth/register
# Login:    POST https://api.sunbird.ai/auth/token
#           body: username=you@email.com&password=yourpassword
SUNBIRD_API_KEY=

# GhanaNLP / Khaya AI (West African: yo, tw, ee, gaa, dag, ki, luo, mer, kus)
# Register: https://translation.ghananlp.org/signup
KHAYA_API_KEY=
KHAYA_API_KEY_SECONDARY=

# HuggingFace (Swahili, French, Arabic, Afrikaans, multilingual fallback)
# Get free token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# ── Permanent demo key (prevents "key expired" errors on Render free tier) ──────
# Generate once: POST /api/v1/auth/keys then copy the key here
# This key is always valid and survives server restarts
FASIRI_DEMO_KEY=

# ── Fasiri internal auth ──────────────────────────────────────
# Generate with: openssl rand -hex 32
FASIRI_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# API key TTL in seconds (default: 1 year)
API_KEY_TTL_SECONDS=31536000

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_BATCH_RPM=10

# ── Redis (optional, for rate limiting across workers) ────────
# Leave blank to use in-memory rate limiting (single worker only)
REDIS_URL=

# ── Provider base URLs (optional overrides) ───────────────────
SUNBIRD_BASE_URL=https://api.sunbird.ai
HUGGINGFACE_BASE_URL=https://router.huggingface.co/hf-inference/models
KHAYA_BASE_URL=https://translation-api.ghananlp.org/v2

# ── Misc ──────────────────────────────────────────────────────
BASE_URL=https://api.fasiri-ai.com
DEBUG=false
HTTP_TIMEOUT=30
HTTP_TIMEOUT_STT=60
DEFAULT_MODEL_ID=Helsinki-NLP/opus-mt-en-mul
